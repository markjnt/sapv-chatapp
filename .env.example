# Domain used by Traefik router label in docker-compose.yaml
# Example: WEB_DOMAIN=chat.example.com
WEB_DOMAIN=''

# Open WebUI image tag (optional in this setup, useful for documentation)
WEBUI_DOCKER_TAG='latest'

# Secret key for Open WebUI sessions/cookies
# Set a long random string in production
WEBUI_SECRET_KEY=''

# Optional: external Ollama endpoint.
# Leave empty if you do not use Ollama.
ENABLE_OLLAMA_API=false
OLLAMA_BASE_URL=''

# Optional OpenAI-compatible endpoint/settings
OPENAI_API_BASE_URL=''
OPENAI_API_KEY=''

# For production, you should only need one host as
# fastapi serves the svelte-kit built frontend and backend from the same host and port.
# To test with CORS locally, you can set something like
# CORS_ALLOW_ORIGIN='http://localhost:5173;http://localhost:8080'
# or for production like this: CORS_ALLOW_ORIGIN='https://chat.example.com'
CORS_ALLOW_ORIGIN='*'

# For production you should set this to match the proxy configuration (127.0.0.1)
FORWARDED_ALLOW_IPS='*'

# DO NOT TRACK
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false